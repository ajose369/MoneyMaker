# Copy this file to .env and fill in your keys.

# Anthropic (story engine, self-review, image QC, metadata) — https://platform.claude.com
ANTHROPIC_API_KEY=

# Google Gemini (images, free-tier LLM, Veo) — https://aistudio.google.com/apikey
# MULTIPLE keys allowed, comma-separated (no quotes, no spaces):
#   GEMINI_API_KEY=AIza...one,AIza...two,AIza...three
# The pipeline rotates keys automatically when one hits its daily quota.
GEMINI_API_KEY=

# Optional overrides
# CLAUDE_MODEL=claude-opus-4-8
# GEMINI_TEXT_MODEL=gemini-3.5-flash
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
# VEO_MODEL=veo-3.1-lite-generate-preview
